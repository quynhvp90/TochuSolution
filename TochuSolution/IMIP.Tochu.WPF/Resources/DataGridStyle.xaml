<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:igDP="http://infragistics.com/DataPresenter"
                    xmlns:converters="clr-namespace:IMIP.Tochu.WPF.Converters">

    <converters:SortIconConverter x:Key="SortIconConverter"/>

    <!-- Template dùng chung cho tất cả sortable header -->
    <!-- Tag = tên field, Text = label hiển thị         -->
    <DataTemplate x:Key="SortableHeaderTemplate">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Dùng Content của LabelPresenter thay vì Tag — Content chính là Label của Field -->
            <TextBlock Text="{Binding}"
                   VerticalAlignment="Center"/>
            <TextBlock Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center">
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource SortIconConverter}">
                        <Binding Path="DataContext.SortField"
                             RelativeSource="{RelativeSource AncestorType=igDP:XamDataGrid}"/>
                        <Binding Path="DataContext.SortAscending"
                             RelativeSource="{RelativeSource AncestorType=igDP:XamDataGrid}"/>
                        <!-- Tag vẫn dùng để converter nhận diện field name -->
                        <Binding Path="Tag"
                             RelativeSource="{RelativeSource AncestorType=igDP:LabelPresenter}"/>
                    </MultiBinding>
                </TextBlock.Text>
                <TextBlock.Opacity>
                    <MultiBinding Converter="{StaticResource SortIconConverter}"
                              ConverterParameter="__opacity">
                        <Binding Path="DataContext.SortField"
                             RelativeSource="{RelativeSource AncestorType=igDP:XamDataGrid}"/>
                        <Binding Path="DataContext.SortAscending"
                             RelativeSource="{RelativeSource AncestorType=igDP:XamDataGrid}"/>
                        <Binding Path="Tag"
                             RelativeSource="{RelativeSource AncestorType=igDP:LabelPresenter}"/>
                    </MultiBinding>
                </TextBlock.Opacity>
            </TextBlock>
        </StackPanel>
    </DataTemplate>
    <!-- Blue header style -->
    <Style x:Key="BlueGridHeaderStyle"
           TargetType="{x:Type igDP:LabelPresenter}"
           BasedOn="{StaticResource {x:Type igDP:LabelPresenter}}">
        <Setter Property="Background"      Value="#1976D2"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="BorderBrush"     Value="#0D47A1"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="ContentTemplate" Value="{StaticResource SortableHeaderTemplate}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1565C0"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#0D47A1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Orange header style -->
    <Style x:Key="OrangeGridHeaderStyle"
           TargetType="{x:Type igDP:LabelPresenter}"
           BasedOn="{StaticResource {x:Type igDP:LabelPresenter}}">
        <Setter Property="Background"      Value="#E65100"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="BorderBrush"     Value="#BF360C"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#BF360C"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#9A2E0A"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Row / Cell styles -->
    <Style TargetType="{x:Type igDP:DataRecordPresenter}"
           BasedOn="{StaticResource {x:Type igDP:DataRecordPresenter}}">
        <Style.Triggers>
            <Trigger Property="IsAlternate" Value="True">
                <Setter Property="Background" Value="#F5F9FF"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E3F2FD"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#BBDEFB"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type igDP:CellValuePresenter}"
           BasedOn="{StaticResource {x:Type igDP:CellValuePresenter}}">
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="BorderBrush"     Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

</ResourceDictionary>