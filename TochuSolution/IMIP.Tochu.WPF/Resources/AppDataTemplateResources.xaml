<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uc="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
    xmlns:windows="clr-namespace:IMIP.Tochu.WPF.Views.Windows"
    xmlns:vm="clr-namespace:IMIP.Tochu.WPF.ViewModels">

    <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
        <uc:Dashboard/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SearchViewModel}">
        <uc:Search/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:MasterViewModel}">
        <uc:Master/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:RegistrationViewModel}">
        <windows:Registration/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:MasterAnalysisViewModel}">
        <uc:MasterAnalysis/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:AnalysisMasterModalViewModel}">
        <windows:AnalysisMasterModal/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:PrintPreviewViewModel}">
        <windows:PrintPreviewWindow/>
    </DataTemplate>
    <!--<DataTemplate DataType="{x:Type vm:ReportViewModel}">
        <uc:ReportView />
    </DataTemplate>-->

</ResourceDictionary>