<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================= COLORS ================= -->
    <Color x:Key="PrimaryBlueLight">#E6F4FF</Color>
    <Color x:Key="PrimaryBlue">#CDE7FF</Color>
    <Color x:Key="PrimaryBlueHoverLight">#D4EEFF</Color>
    <Color x:Key="PrimaryBlueHover">#A9DAFF</Color>
    <Color x:Key="PrimaryBluePressedLight">#B8DFFF</Color>
    <Color x:Key="PrimaryBluePressed">#8CCBFF</Color>

    <!-- ================= BRUSHES ================= -->
    <LinearGradientBrush x:Key="BtnBackgroundNormal" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource PrimaryBlueLight}" Offset="0"/>
        <GradientStop Color="{StaticResource PrimaryBlue}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BtnBackgroundHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource PrimaryBlueHoverLight}" Offset="0"/>
        <GradientStop Color="{StaticResource PrimaryBlueHover}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BtnBackgroundPressed" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource PrimaryBluePressedLight}" Offset="0"/>
        <GradientStop Color="{StaticResource PrimaryBluePressed}" Offset="1"/>
    </LinearGradientBrush>

    <!-- ================= BUTTON STYLE ================= -->
    <Style x:Key="SoftBlueButton" TargetType="Button">
        <Setter Property="Foreground" Value="#2C3E50"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="{StaticResource BtnBackgroundNormal}"/>
        <Setter Property="BorderBrush" Value="#A0CFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">

                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{StaticResource BtnBackgroundHover}"/>
                            <Setter Property="BorderBrush" Value="#7FBFFF"/>
                        </Trigger>

                        <!-- Press -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="{StaticResource BtnBackgroundPressed}"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>