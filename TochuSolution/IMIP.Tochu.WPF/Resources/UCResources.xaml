<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:uc="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
    xmlns:windows="clr-namespace:IMIP.Tochu.WPF.Views.Windows"
    xmlns:vm="clr-namespace:IMIP.Tochu.WPF.ViewModels">

    <DataTemplate DataType="{x:Type vm:MainViewModel}">
        <uc:Main/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:SearchViewModel}">
        <uc:SearchView/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:MasterViewModel}">
        <uc:Master/>
    </DataTemplate>
    <DataTemplate DataType="{x:Type vm:RegistrationViewModel}">
        <windows:Registration/>
    </DataTemplate>

</ResourceDictionary>