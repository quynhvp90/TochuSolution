<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:Editors="http://schemas.infragistics.com/xaml/wpf">
    <SolidColorBrush x:Key="BootstrapBorderBrush" Color="#CED4DA" />
    <SolidColorBrush x:Key="BootstrapFocusBorderBrush" Color="#86B7FE" />
    <SolidColorBrush x:Key="BootstrapPlaceholderBrush" Color="#6C757D" />
    
    <Style x:Key="CleanTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="BootstrapXamEditor" TargetType="{x:Type Editors:XamTextEditor}">
        <Setter Property="Height" Value="38"/>
          <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BootstrapBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="BootstrapEditorContainer" TargetType="Border">
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BootstrapBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="6"
                              ShadowDepth="0"
                              Opacity="0.12"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource BootstrapFocusBorderBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.25"/>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.6"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>