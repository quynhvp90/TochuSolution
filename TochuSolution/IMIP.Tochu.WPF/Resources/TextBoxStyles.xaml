<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:Editors="http://schemas.infragistics.com/xaml/wpf">
    <SolidColorBrush x:Key="BootstrapBorderBrush" Color="#CED4DA" />
    <SolidColorBrush x:Key="BootstrapFocusBorderBrush" Color="#86B7FE" />
    <SolidColorBrush x:Key="BootstrapPlaceholderBrush" Color="#6C757D" />
    <Style x:Key="CleanTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="BootstrapXamEditor" TargetType="{x:Type Editors:XamTextEditor}">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BootstrapBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Editors:XamTextEditor}">
                    <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <TextBlock x:Name="PlaceholderText"
                                       Text="{TemplateBinding NullText}"
                                       Foreground="{StaticResource BootstrapPlaceholderBrush}"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"
                                       FontStyle="Italic"/>

                            <ContentPresenter x:Name="PART_ContentHost" 
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource BootstrapFocusBorderBrush}"/>
                            <Setter TargetName="MainBorder" Property="BorderThickness" Value="1.5"/>
                            <Setter TargetName="MainBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="#0D6EFD" Opacity="0.25"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>