<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IMIP.Tochu.WPF.Views.Windows"
        xmlns:igWPF="http://schemas.infragistics.com/xaml/wpf" 
        x:Class="IMIP.Tochu.WPF.Views.Windows.Registration"
        xmlns:ig="http://schemas.infragistics.com/xaml"
        xmlns:igEditors="http://schemas.infragistics.com/xaml/wpf"
        xmlns:vmDesign="clr-namespace:IMIP.Tochu.WPF.DataDesign"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vmDesign:RegistrationDesignViewModel, IsDesignTimeCreatable=True}"
        Width="900" Height="750"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen"
        FontFamily="Meiryo UI, Yu Gothic UI, MS Gothic, sans-serif"
        FontSize="11"
        Title="Registration">
    <Window.Resources>
        <!-- Common style for Infragistics XamTextEditor (input fields) -->
        <Style x:Key="InputEditorStyle" TargetType="igEditors:XamTextEditor">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Green-tinted input style (受注情報 area) -->
        <Style x:Key="GreenInputStyle" TargetType="igEditors:XamTextEditor" BasedOn="{StaticResource InputEditorStyle}">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
        <!--XamDateTimeEditorStyle-->
        <Style x:Key="XamDateTimeEditorStyle" TargetType="igEditors:XamDateTimeEditor">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,1"/>
            
        </Style>
        <!--GreenXamDateTimeEditorStyle-->
        <Style x:Key="GreenXamDateTimeEditorStyle"
           TargetType="{x:Type igEditors:XamDateTimeEditor}"
           BasedOn="{StaticResource XamDateTimeEditorStyle}">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type igEditors:XamDateTimeEditor}">
                        <Border BorderBrush="#FFABABAB"
                            BorderThickness="1">

                            <Grid>
                                <igEditors:XamDateTimeEditor
                                    Value="{TemplateBinding Value}"
                                    Background="#FFE8F5E9"
                                    BorderThickness="0"/>
                            </Grid>

                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
        <!--XamNumericEditor-->
        <Style x:Key="InputNumericEditorStyle" TargetType="igEditors:XamNumericEditor">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <!-- Yellow/beige-tinted input style (ロット番号) -->
        <Style x:Key="YellowInputStyle" TargetType="igEditors:XamTextEditor" BasedOn="{StaticResource InputEditorStyle}">
            <Setter Property="Background" Value="#FFF9C4"/>
        </Style>
        <!--XamComboEditor-->
        <Style x:Key="InputComboEditorStyle" TargetType="igEditors:XamComboEditor">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <!--XamNumericEditor-->
        <Style x:Key="XamNumericEditorStyle" TargetType="igEditors:XamNumericEditor">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,1"/>
        </Style>
        <!-- XamMaskedEditorStyle -->
        <Style x:Key="XamMaskedEditorStyle" TargetType="igEditors:XamMaskedEditor">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <!-- decimal -->
            <Setter Property="Mask" Value="nnnnnn.nn"/>
            <Setter Property="PromptChar" Value=" "/>
        </Style>

        <!--Yellow XamMaskedEditor style-->
        <Style x:Key="YellowXamMaskedEditorStyle" TargetType="igEditors:XamMaskedEditor" BasedOn="{StaticResource XamMaskedEditorStyle}">
            <Setter Property="Background" Value="#FFF9C4"/>
        </Style>
        <!--XamMaskedEditor Disabled style-->

        <Style x:Key="DisabledXamMaskedEditorStyle" TargetType="igEditors:XamMaskedEditor" BasedOn="{StaticResource XamMaskedEditorStyle}">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Opacity" Value="0.8"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
        <!--Green XamMaskedEditor style-->
        <Style x:Key="GreenXamMaskedEditorStyle" TargetType="igEditors:XamMaskedEditor" BasedOn="{StaticResource XamMaskedEditorStyle}">
            <Setter Property="Background" Value="#E8F5E9"/>
        </Style>
        <!-- Blue analysis value style -->
        <Style x:Key="BlueXamMaskedEditorStyle" TargetType="igEditors:XamMaskedEditor" BasedOn="{StaticResource XamMaskedEditorStyle}">
            <Setter Property="Background" Value="#E3F2FD"/>
        </Style>


        <!-- Label style -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>

        <!-- Blue text label (A1, B1 etc.) -->
        <Style x:Key="BlueLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- Section border style -->
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="2"/>
        </Style>
    </Window.Resources>
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header section -->
            <RowDefinition Height="Auto"/>
            <!-- Controls section -->
            <RowDefinition Height="*"/>
            <!-- Main analysis area -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ========== ROW 0: Header / Order Info ========== -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Line 1: 注文伝票, 受注日, 納期, fields 15 & 16 -->
                <Grid Grid.Row="0" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Order Slip" Style="{StaticResource FieldLabelStyle}"/>
                    <igEditors:XamTextEditor Grid.Column="1"
                    Style="{StaticResource GreenInputStyle}"
                    Text="{Binding JuchuuRCS.JuchuuDenpyouNO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    x:Name="Field2" Theme="Office2013"/>

                    <TextBlock Grid.Column="2" Text="Order Date" Style="{StaticResource FieldLabelStyle}" Margin="4,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamDateTimeEditor Grid.Column="3"
                        Style="{StaticResource GreenXamDateTimeEditorStyle}"
                        Value="{Binding JuchuuRCS.JuchuuYMD, Mode=TwoWay}"
                        x:Name="Field3" Theme="Office2013"/>

                    <TextBlock Grid.Column="4" Text="Delivery Date" Style="{StaticResource FieldLabelStyle}" Margin="4,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamDateTimeEditor Grid.Column="5"
                        Style="{StaticResource GreenXamDateTimeEditorStyle}"
                        Value="{Binding JuchuuRCS.Nouki, Mode=TwoWay}"
                        x:Name="Field4" Theme="Office2013"/>

                    <igEditors:XamTextEditor Grid.Column="7"
                        Style="{StaticResource GreenInputStyle}"
                        Text="{Binding SeinouData.NUM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="Field15" Theme="Office2013"/>

                    <igEditors:XamTextEditor Grid.Column="9"
                        Style="{StaticResource GreenInputStyle}"
                        Text="{Binding StatusAddnew, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    x:Name="Field16" Theme="Office2013"/>
                </Grid>

                <!-- Line 2: 顧客名, 顧客コード, 先方品番 -->
                <Grid Grid.Row="1" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Customer Name" Style="{StaticResource FieldLabelStyle}"/>
                    <igEditors:XamTextEditor Grid.Column="1"
                    Style="{StaticResource GreenInputStyle}"
                    Text="{Binding JuchuuRCS.NouSSNM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    x:Name="Field5" Theme="Office2013"/>

                    <TextBlock Grid.Column="2" Text="Customer Code" Style="{StaticResource FieldLabelStyle}" Margin="6,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamTextEditor Grid.Column="3"
                    Style="{StaticResource GreenInputStyle}"
                    Text="{Binding JuchuuRCS.NouSSCD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    x:Name="Field6" Theme="Office2013"/>

                    <TextBlock Grid.Column="5" Text="Part Number" Style="{StaticResource FieldLabelStyle}" Margin="6,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamTextEditor Grid.Column="6"
                        Style="{StaticResource GreenInputStyle}"
                        Text="{Binding JuchuuRCS.UserHinban, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="Field7" Theme="Office2013"  />
                </Grid>

                <!-- Line 3: 製品名, 荷姿, 数量, 単位 -->
                <Grid Grid.Row="2" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Product Name" Style="{StaticResource FieldLabelStyle}"/>
                    <igEditors:XamTextEditor Grid.Column="1"
                        Style="{StaticResource GreenInputStyle}"
                        Text="{Binding JuchuuRCS.UserHinmei, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="Field8"/>

                    <TextBlock Grid.Column="2" Text="Packaging Style" Style="{StaticResource FieldLabelStyle}" Margin="6,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamTextEditor Grid.Column="3"
                        Style="{StaticResource GreenInputStyle}"
                        Text="{Binding JuchuuRCS.NisugataCD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="Field9"/>

                    <TextBlock Grid.Column="5" Text="Quantity" Style="{StaticResource FieldLabelStyle}" Margin="6,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamNumericEditor Grid.Column="6"
                        Style="{StaticResource InputNumericEditorStyle}"
                        Background="#E8F5E9"
                        BorderBrush="#AAAAAA"
                        Value="{Binding JuchuuRCS.JuchuuSuu, Mode=TwoWay}"
                        x:Name="Field10"/>

                    <TextBlock Grid.Column="7" Text="Unit" Style="{StaticResource FieldLabelStyle}" Margin="6,0,4,0" HorizontalAlignment="Right"/>
                    <igEditors:XamTextEditor Grid.Column="8"
                        Style="{StaticResource GreenInputStyle}"
                        Text="{Binding JuchuuRCS.TankaUnitCD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="Field11"/>
                </Grid>

                <!-- Line 4: ロット番号 + Dropdowns 12,13,14 -->
                <Grid Grid.Row="3" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Lot Number" Style="{StaticResource FieldLabelStyle}" FontSize="10"/>
                    <igEditors:XamTextEditor Grid.Column="1"
                        Style="{StaticResource YellowInputStyle}"
                        VerticalContentAlignment="Center"
                        Text="{Binding SeinouData.LOTNO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        x:Name="Field1"/>

                    <!-- Dropdown 12 -->
                    <igEditors:XamComboEditor Grid.Column="3"
                        Background="#FFF9C4"
                        BorderBrush="#AAAAAA"
                        Style="{StaticResource InputComboEditorStyle}"
                        ItemsSource="{Binding Tantou1Items}"
                        SelectedItem="{Binding SelectedTantou1, Mode=TwoWay}"
                        x:Name="Field12"/>

                    <!-- Dropdown 13 -->
                    <igEditors:XamComboEditor Grid.Column="5"
                        Background="#FFF9C4"
                        BorderBrush="#AAAAAA"
                        Style="{StaticResource InputComboEditorStyle}"
                        ItemsSource="{Binding Tantou2Items}"
                        SelectedItem="{Binding SelectedTantou2, Mode=TwoWay}"
                        x:Name="Field13"/>

                    <!-- Dropdown 14 -->
                    <igEditors:XamComboEditor Grid.Column="7"
                        Style="{StaticResource InputComboEditorStyle}"
                        Background="#FFF9C4"
                        BorderBrush="#AAAAAA"
                        ItemsSource="{Binding Tantou3Items}"
                        SelectedItem="{Binding SelectedTantou3, Mode=TwoWay}"
                        x:Name="Field14"/>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== ROW 1: Control Buttons + Print Date ========== -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <!-- 分析値マスタ呼出 button -->
                <Button Grid.Column="0"
                    Style="{StaticResource BlueButtonStyle}"
                    Width="140" 
                    Command="{Binding LoadMasterCommand}"
                    Content="Call Analysis Master"
                    TextBlock.TextAlignment="Center"/>

                <!-- Field 20 -->
                <igEditors:XamTextEditor Grid.Column="2"
                    Style="{StaticResource GreenInputStyle}"
                    Text="{Binding JuchuuRCS.NouSCD, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    x:Name="Field20" Margin="1,0,1,0"/>
                

                <!-- 印刷日 label + Field 17 -->
                <TextBlock Grid.Column="3" Text="Print Date" Style="{StaticResource FieldLabelStyle}" Margin="8,0,4,0"/>
                <igEditors:XamDateTimeEditor Grid.Column="4"
                    Style="{StaticResource GreenXamDateTimeEditorStyle}"
                    Value="{Binding SeinouData.PRINTDT, Mode=TwoWay}"  Theme="Office2013"
                    x:Name="Field17" Margin="1,0,1,0"/>

                <!-- 自動 button -->
                <Button Grid.Column="6"
                    Style="{StaticResource GreenButtonStyle}"
                    Command="{Binding AutoCommand}"
                    Content="Auto"/>

                <!-- クリア button -->
                <Button Grid.Column="8"
                    Style="{StaticResource BlueButtonStyle}"
                    Command="{Binding ClearCommand}"
                    Content="Clear"/>
            </Grid>
        </Border>

        <!-- ========== ROW 2: Analysis Data + Chart ========== -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <!-- Left: analysis inputs -->
                    <ColumnDefinition Width="*"/>
                    <!-- Right: chart + 抗折力 -->
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT: Analysis input table ===== -->
                <StackPanel Grid.Column="0" Margin="0,0,6,0">

                    <!-- Resin Content -->
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Resin Content" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T10A, StringFormat=0 ~ {0}}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor Grid.Column="2"
                            Style="{StaticResource YellowXamMaskedEditorStyle}"
                            Value="{Binding SeinouData.T10, Mode=TwoWay}"
                            x:Name="Field21"/>
                    </Grid>

                    <!-- Adhesion Point -->
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Adhesion Point" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T20A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor Grid.Column="2"
                            Style="{StaticResource YellowXamMaskedEditorStyle}"
                            Value="{Binding SeinouData.T40, Mode=TwoWay}"
                            x:Name="Field22"/>
                    </Grid>

                    <!-- m14 ~ m280 rows -->
                    <ItemsControl ItemsSource="{Binding MeshItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="35"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding MeshLabel}" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ALabel}" Style="{StaticResource BlueLabelStyle}"/>
                                    <TextBlock Grid.Column="2" Text="～" Style="{StaticResource FieldLabelStyle}" FontSize="10"/>
                                    <TextBlock Grid.Column="3" Text="{Binding BLabel}" Style="{StaticResource BlueLabelStyle}"/>
                                    <igEditors:XamMaskedEditor Grid.Column="4"
                                        Style="{StaticResource XamMaskedEditorStyle}"
                                        Value="{Binding Value, Mode=TwoWay}"
                                        x:Name="MeshField"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m14" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T50A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor Grid.Column="2"
                            Style="{StaticResource YellowXamMaskedEditorStyle}"
                            Value="{Binding SeinouData.T50, Mode=TwoWay}"
                            x:Name="FieldM14"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m18.5" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T60A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM18_5" Value="{Binding SeinouData.T60, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m26" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T70A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM26" Value="{Binding SeinouData.T70, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m36" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T80A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM36" Value="{Binding SeinouData.T80, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m50" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T90A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM50" Value="{Binding SeinouData.T90, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m70" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T100A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM70" Value="{Binding SeinouData.T100, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m100" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T110A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM100" Value="{Binding SeinouData.T110, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m140" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T120A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM140" Value="{Binding SeinouData.T120, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m200" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T130A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM200" Value="{Binding SeinouData.T130, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="m280" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T140A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldM280" Value="{Binding SeinouData.T140, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="mPAN" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T150A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldMPan" Value="{Binding SeinouData.T150, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource YellowXamMaskedEditorStyle}"/>
                    </Grid>
                    <!--mTotal-->
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="mTotal" Style="{StaticResource FieldLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldMTotal" Value="{Binding SeinouData.MA150, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource DisabledXamMaskedEditorStyle}"/>
                    </Grid>
                    <!-- AFS.FN -->
                    <Grid Margin="0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="AFS.FN" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T160A}" Style="{StaticResource BlueLabelStyle}"/>
                        <igEditors:XamMaskedEditor x:Name="FieldAFS_FN" Value="{Binding SeinouData.T160, Mode=TwoWay}" Grid.Column="2" Style="{StaticResource DisabledXamMaskedEditorStyle}"/>
                    </Grid>
                
                </StackPanel>

                <!-- ===== RIGHT: 抗折力 + Chart ===== -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- 抗折力 rows -->
                        <RowDefinition Height="*"/>
                        <!-- Chart -->
                    </Grid.RowDefinitions>

                    <!-- 抗折力 A2~B2 and A3~B3 -->
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 抗折力I A2 ~ B2 -->
                        <Grid Grid.Row="0" Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="145"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Transverse Rupture Strength X" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T30A}" Style="{StaticResource BlueLabelStyle}"/>
                            <igEditors:XamMaskedEditor Grid.Column="2"
                                Style="{StaticResource YellowXamMaskedEditorStyle}"
                                Width="60"
                                Value="{Binding SeinouData.T20, Mode=TwoWay}"
                                x:Name="Field35"/>
                            <TextBlock Grid.Column="3" Text="kgf/cm²" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center"/>
                            <igEditors:XamMaskedEditor Grid.Column="4"
                                Style="{StaticResource XamMaskedEditorStyle}"
                                Value="{Binding SeinouData.MA20, Mode=OneWay}"
                                x:Name="Field36"/>
                            <TextBlock Grid.Column="5" Text="N/cm²" Style="{StaticResource FieldLabelStyle}" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- 抗折力I A3 ~ B3 -->
                        <Grid Grid.Row="1" Margin="0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="145"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Transverse Rupture Strength R" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Grid.Column="1" Text="{Binding SeinouMstSE.T40A}" Style="{StaticResource BlueLabelStyle}"/>
                            <igEditors:XamMaskedEditor Grid.Column="2"
                                Style="{StaticResource YellowXamMaskedEditorStyle}"
                                Width="60"
                                Value="{Binding SeinouData.T30, Mode=TwoWay}"
                                x:Name="Field37"/>
                            <TextBlock Grid.Column="3" Text="kgf/cm²" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center"/>
                            <igEditors:XamMaskedEditor Grid.Column="4"
                                Style="{StaticResource XamMaskedEditorStyle}"
                                Value="{Binding SeinouData.MA30, Mode=OneWay}"
                                x:Name="Field38"/>
                            <TextBlock Grid.Column="5" Text="N/cm²" Style="{StaticResource FieldLabelStyle}" Margin="4,0,0,0"/>
                        </Grid>
                    </Grid>

                    <!-- ===== グラフエリア (Infragistics XamDataChart) ===== -->
                    <Border Grid.Row="1"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Background="White"
                        Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                Text="Graph Area"
                                Foreground="#1565C0"
                                FontWeight="Bold"
                                FontSize="11"
                                Margin="0,0,0,4"/>
                                <ig:XamDataChart Grid.Row="1"
                                x:Name="AnalysisChart"
                                CrosshairVisibility="Collapsed">

                                <ig:XamDataChart.Axes>
                                    <!-- X Axis: MESH categories -->
                                    <ig:CategoryXAxis x:Name="xAxis"
                                    ItemsSource="{Binding ChartData}"
                                    Label="{}{MeshLabel}"
                                    Title="MESH" Foreground="#555555"
                                                     
                                    MajorStroke="#DDDDDD"
                                    Stroke="#AAAAAA"/>

                                    <!-- Y Axis: % value -->
                                    <ig:NumericYAxis x:Name="yAxis"
                                    MinimumValue="0"
                                    MaximumValue="70"
                                    Interval="10"
                                    Title="%"
                                    Foreground="#555555"
                                    MajorStroke="#DDDDDD"
                                    Stroke="#AAAAAA"/>
                                </ig:XamDataChart.Axes>

                                <ig:XamDataChart.Series>
                                    <ig:LineSeries
                                    x:Name="AnalysisSeries"
                                    XAxis="{Binding ElementName=xAxis}"
                                    YAxis="{Binding ElementName=yAxis}"
                                    ItemsSource="{Binding ChartData}"
                                    ValueMemberPath="Value"
                                    Brush="#444444"
                                    Thickness="1.5"
                                    MarkerType="Circle"
                                    MarkerBrush="#444444"
                                    MarkerOutline="#444444"/>
                                </ig:XamDataChart.Series>
                            </ig:XamDataChart>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== ROW 3: Footer (備考 + 印刷IN) ========== -->
        <Border Grid.Row="3" Style="{StaticResource SectionBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Remarks" Style="{StaticResource FieldLabelStyle}" FontSize="10"/>

                <!-- Field 40: 備考 / Ghi chú -->
                <igEditors:XamTextEditor Grid.Column="1"
                Style="{StaticResource YellowInputStyle}"
                Text="{Binding SeinouData.COMM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                x:Name="Field40"/>

                <!-- Print button -->
                <Button Grid.Column="2"
                    Style="{StaticResource BlueButtonStyle}"
                    Width="100"
                    Command="{Binding PrintCommand}"
                    Content="Print"/>
            </Grid>
        </Border>
    </Grid>
</Window>
