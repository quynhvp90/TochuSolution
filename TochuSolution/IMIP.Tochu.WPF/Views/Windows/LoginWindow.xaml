<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:igWPF="http://schemas.infragistics.com/xaml/wpf" x:Class="IMIP.Tochu.WPF.Views.Windows.LoginWindow"
        Title="Login"
        Width="450"
        Height="500"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Grid Background="Transparent">

        <Border Width="400"
                Height="450"
                Padding="5"
                Background="White"
                CornerRadius="18"
                HorizontalAlignment="Center"
                MouseLeftButtonDown="Border_MouseLeftButtonDown"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="25"
                                  ShadowDepth="0"
                                  Opacity="0.2"/>
            </Border.Effect>

            <StackPanel>
                <Button x:Name="Close" Content="✕"
                        Width="30"
                        Height="30"
                        Style="{StaticResource CloseButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="Black"
                        Click="Close_Click"/>

                <Border Padding="25,0,25,25" Height="400">
                    <StackPanel VerticalAlignment="Center">

                        <!-- Title -->
                        <TextBlock Text="Login"
                                FontSize="20"
                                FontWeight="Bold"
                                Margin="0,0,0,15"
                                HorizontalAlignment="Center"/>

                        <!-- Username -->
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Grid>
                                <TextBlock Text="👤"
                                        FontSize="14"
                                        VerticalAlignment="Center"
                                        Margin="12,0"/>

                                <TextBox Visibility="Hidden"
                                        Style="{StaticResource CleanTextBox}"
                                        Margin="38,0,10,0"/>
                                <igWPF:XamTextEditor HorizontalAlignment="Left" Text="{Binding Username}" 
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Margin="38,0,0,0" VerticalAlignment="Center" Height="45" Width="292" VerticalContentAlignment="Center">
                                    
                                </igWPF:XamTextEditor>
                            </Grid>
                        </Border>

                        <!-- Password -->
                        <Border Style="{StaticResource InputContainerStyle}">
                            <Grid>
                                <TextBlock Text="🔒"
                                        FontSize="14"
                                        VerticalAlignment="Center"
                                        Margin="12,0"/>

                                <PasswordBox x:Name="pwd"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalContentAlignment="Center"
                                            Margin="38,0,10,0"/>
                            </Grid>
                        </Border>

                        <!-- Button -->
                        <Button Content="Login"
                            Style="{StaticResource SoftBlueButton}"
                            Margin="0,15,0,0" Height="40" Cursor="Hand"
                            Click="btnLogin_Click"/>

                    </StackPanel>
                </Border>
            </StackPanel>

        </Border>
        <!-- Card -->

    </Grid>
</Window>