<Window x:Class="IMIP.Tochu.WPF.Views.Windows.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IMIP.Tochu.WPF.Views.Windows"
        xmlns:views="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
        mc:Ignorable="d"
        Title="Print Preview"
        Width="860" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#666666">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#444444" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="🖨 Print"
                    Width="100" Height="28" Margin="0,0,8,0"
                    Command="{Binding PrintCommand}"/>
                <Button Content="💾 Export PDF"
                    Width="120" Height="28" Margin="0,0,8,0"
                    Command="{Binding ExportPdfCommand}"/>
                <Button Content="✕ Close"
                    Width="80" Height="28"
                    Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Border>

        <!-- Scrollable preview -->
        <ScrollViewer Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.4" ShadowDepth="4"/>
                </Border.Effect>
                <views:ReportView x:Name="ReportContent" DataContext="{Binding Report}"/>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
