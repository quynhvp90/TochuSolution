<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IMIP.Tochu.WPF"
        xmlns:ig="http://schemas.infragistics.com/xaml" 
        x:Class="IMIP.Tochu.WPF.MainWindow"
        xmlns:views="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
        xmlns:vm="clr-namespace:IMIP.Tochu.UI.ViewModels;assembly=IMIP.Tochu.UI" 
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal" Margin="0,0,0,320">
            <Button Content="Search"
                    Command="{Binding NavigateToSearchCommand}"
                    Width="80" Margin="0,0,4,0"/>
            <Button Content="Master"
                    Command="{Binding NavigateToMasterCommand}"
                    Width="80"/>
            <ig:XamButton Content="XamButton"/>
        </StackPanel>
        <ContentControl Content="{Binding CurrentView}" Margin="0,119,0,0"/>
        <!-- Content -->
    </Grid>
</Window>
