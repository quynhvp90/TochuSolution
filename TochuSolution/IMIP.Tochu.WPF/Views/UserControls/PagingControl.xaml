<UserControl x:Class="IMIP.Tochu.WPF.Views.UserControls.PagingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:igEditors="http://infragistics.com/Editors"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White" Padding="10,5"
            BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Total info -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Total: " Foreground="#555" FontSize="12"/>
                <TextBlock Text="{Binding TotalCount}" Foreground="#1565C0"
                           FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Text=" records  |  Page " Foreground="#555" FontSize="12"/>
                <TextBlock Text="{Binding CurrentPage}" FontWeight="SemiBold"
                           Foreground="#1565C0" FontSize="12"/>
                <TextBlock Text=" / " Foreground="#555" FontSize="12"/>
                <TextBlock Text="{Binding TotalPages}" Foreground="#555" FontSize="12"/>
            </StackPanel>

            <!-- Page size -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="Rows/page:" VerticalAlignment="Center"
                           Foreground="#555" FontSize="12" Margin="0,0,6,0"/>
                <igEditors:XamComboEditor ItemsSource="{Binding PageSizeOptions}"
                        SelectedItem="{Binding PageSize, Mode=TwoWay}"
                        Width="65" Height="24" FontSize="12" NullText="20" HorizontalContentAlignment="Center"
                        IsEditable="False"/>
            </StackPanel>

            <!-- Navigation -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="⏮" Command="{Binding FirstPageCommand}"
                        Width="28" Height="24" Margin="2,0" FontSize="13"
                        Background="White" BorderBrush="#BDBDBD" ToolTip="First"/>
                <Button Content="◀" Command="{Binding PrevPageCommand}"
                        Width="28" Height="24" Margin="2,0" FontSize="12"
                        Background="White" BorderBrush="#BDBDBD" ToolTip="Prev"/>

                <!-- Jump to page -->
                <Border BorderBrush="#1976D2" BorderThickness="1"
                        CornerRadius="2" Margin="4,0">
                    <igEditors:XamNumericEditor
                        Width="36" Height="22"
                        BorderThickness="0"
                        FontSize="12" HorizontalContentAlignment="Center" NullText="1"
                        Value="{Binding CurrentPage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                        SpinButtonDisplayMode="Never"
                        Mask="nnn" Theme="Office2013">
                        <igEditors:XamNumericEditor.ValueConstraint>
                            <igEditors:ValueConstraint MinInclusive="1"/>
                        </igEditors:XamNumericEditor.ValueConstraint>
                        <igEditors:XamNumericEditor.InputBindings>
                            <KeyBinding Key="Return"
                                Command="{Binding GoToPageCommand}"
                                CommandParameter="{Binding Value,
                                RelativeSource={RelativeSource AncestorType=igEditors:XamNumericEditor}}"/>
                        </igEditors:XamNumericEditor.InputBindings>
                    </igEditors:XamNumericEditor>
                </Border>

                <Button Content="▶" Command="{Binding NextPageCommand}"
                        Width="28" Height="24" Margin="2,0" FontSize="12"
                        Background="White" BorderBrush="#BDBDBD" ToolTip="Next"/>
                <Button Content="⏭" Command="{Binding LastPageCommand}"
                        Width="28" Height="24" Margin="2,0" FontSize="13"
                        Background="White" BorderBrush="#BDBDBD" ToolTip="Last"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>