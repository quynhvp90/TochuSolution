<UserControl x:Class="IMIP.Tochu.WPF.Views.UserControls.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:ig="http://schemas.infragistics.com/xaml"
             xmlns:local="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
             xmlns:loc="clr-namespace:IMIP.Tochu.WPF.Helpers"
             mc:Ignorable="d"
             Width="794" Height="1123"
            Background="White"
            FontFamily="Meiryo UI, Yu Gothic UI, MS Gothic, sans-serif">
    <!-- A4 size: 794x1123px at 96dpi -->
    <Border Margin="30" BorderBrush="#333333" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title + Logo -->
                <RowDefinition Height="Auto"/>
                <!-- Customer + Address -->
                <RowDefinition Height="Auto"/>
                <!-- Info table -->
                <RowDefinition Height="Auto"/>
                <!-- 検査結果 section -->
                <RowDefinition Height="*"/>
                <!-- Chart -->
                <RowDefinition Height="Auto"/>
                <!-- 備考 -->
            </Grid.RowDefinitions>

            <!-- ===== ROW 0: Title + Logo ===== -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="{loc:Loc Key=Report_Title}" TextDecorations="Underline"
                    FontSize="18" FontWeight="Bold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <!-- Company logo area -->
                
            </Grid>

            <!-- ===== ROW 1: Customer + Address ===== -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Customer name + 御中 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding CompanyName}"
                        FontSize="14" FontWeight="Bold"
                        VerticalAlignment="Bottom"/>
                    <TextBlock Padding="50, 0, 0, 0" Text="{loc:Loc Key=Report_Honorific}"
                        FontSize="12"
                        VerticalAlignment="Bottom"/>
                </StackPanel>

                <!-- logo + Address + Date -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Border BorderBrush="#333333" BorderThickness="1" Padding="8,4" MinWidth="160">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Key=Report_CompanyName}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{loc:Loc Key=Report_OfficeName}" FontSize="9" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{loc:Loc Key=Report_Address}"
                        FontSize="8" HorizontalAlignment="Right"/>
                    <TextBlock Text="{loc:Loc Key=Report_Phone}"
                        FontSize="8" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- Separator line -->
            <!--<Separator Grid.Row="1" VerticalAlignment="Bottom" Margin="0,0,0,0"/>-->

            <!-- ===== ROW 2: Info table (品名, 樹脂分, 製造No, 担当, 数量) ===== -->
            <Grid Grid.Row="2" Margin="0,6,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: 品名 / 樹脂分 / 製造No -->
                <Border Grid.Column="0" BorderBrush="#333333" Width="300" BorderThickness="1" Margin="0,0,4,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" BorderBrush="#333333" BorderThickness="0,0,1,1">
                            <TextBlock Text="{loc:Loc Key=Report_ProductNameLabel}" VerticalAlignment="Center" Margin="6,0" FontSize="10"/>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="#333333" BorderThickness="0,0,0,1">
                            <TextBlock Text="{Binding ProductName}" VerticalAlignment="Center" Margin="6,0" FontSize="11" FontWeight="Bold"/>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#333333" BorderThickness="0,0,1,1">
                            <TextBlock Text="{loc:Loc Key=Report_ResinContentLabel}" VerticalAlignment="Center" Margin="6,0" FontSize="10"/>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="#333333" BorderThickness="0,0,0,1">
                            <TextBlock VerticalAlignment="Center" Margin="6,0" FontSize="10">
                                <Run Text="{Binding ResinContent}"/><Run Text=" %"/>
                            </TextBlock>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" BorderBrush="#333333" BorderThickness="0,0,1,0">
                            <TextBlock Text="{loc:Loc Key=Report_LotNoLabel}" VerticalAlignment="Center" Margin="6,0" FontSize="10"/>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1">
                            <TextBlock Text="{Binding LotNo}" VerticalAlignment="Center" Margin="6,0" FontSize="10"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right: 担当 + 数量 -->
                <Grid Grid.Column="2" Width="200">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*"/>
                        <ColumnDefinition Width="60*"/>
                        <ColumnDefinition Width="60*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="#333333" BorderThickness="1,1,1,0">
                        <TextBlock Text="{Binding PrintDate}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                    </Border>
                    <!-- 担当3, 担当2, 担当1 -->
                    <Border Grid.Row="1" Grid.Column="0" BorderBrush="#333333" BorderThickness="1,1,0,0">
                        <TextBlock Text="{Binding Tantou3}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="1" BorderBrush="#333333" BorderThickness="1,1,0,0">
                        <TextBlock Text="{Binding Tantou2}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" BorderBrush="#333333" BorderThickness="1,1,1,0">
                        <TextBlock Text="{Binding Tantou1}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                    </Border>

                    <!-- 数量 -->
                    <Border Grid.Row="2" Grid.Column="0" BorderBrush="#333333" BorderThickness="1,1,0,1">
                        <TextBlock Text="{loc:Loc Key=Report_QuantityLabel}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" BorderBrush="#333333" BorderThickness="1,1,1,1">
                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== ROW 3: 検査結果 ===== -->
            <Border Grid.Row="3" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- 抵抗力 header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Values -->
                        <RowDefinition Height="Auto"/>
                        <!-- 分布 row -->
                    </Grid.RowDefinitions>

                    <!-- 検査結果 title -->
                    <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <!--<TextBlock Text="検査結果" FontSize="11" FontWeight="Bold"/>-->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!--Row 1-->
                            <Border Grid.Column="0" Grid.Row="0"  Grid.ColumnSpan="2" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,2">
                                <TextBlock Text="{loc:Loc Key=Report_ResistanceLabel}" FontSize="9" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Grid.RowSpan="2" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,2">
                                <TextBlock Text="{loc:Loc Key=Report_AdhesionLabel}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Grid.RowSpan="2" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="4,2">
                            </Border>
                            <!--Row 2-->
                            <Border Grid.Column="0" Grid.Row="1" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,2">
                                <TextBlock Text="X" HorizontalAlignment="Center" FontSize="9"/>
                            </Border>
                            <Border Grid.Column="1" Grid.Row="1" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,2">
                                <TextBlock Text="Y" HorizontalAlignment="Center" FontSize="9"/>
                            </Border>
                            <Border Grid.Column="3" Grid.Row="2" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="4,2">
                            </Border>
                            <!--Row 3-->
                            <Border Grid.Column="0" Grid.Row="2" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontSize="10"> <Run Text="{Binding XN}"/><Run Text=" N/㎝²"/> </TextBlock>
                                    <TextBlock HorizontalAlignment="Center" FontSize="10"> <Run Text="{Binding XK}"/><Run Text=" kgf/㎝²"/> </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Grid.Row="2" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,3">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontSize="10">
                                        <Run Text="{Binding YN}"/><Run Text=" N/㎝²"/>
                                    </TextBlock>
                                    <TextBlock HorizontalAlignment="Center" FontSize="10">
                                        <Run Text="{Binding YK}"/><Run Text=" kgf/㎝²"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Grid.Row="2" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="4,2">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"> <Run Text="{Binding AdhesionPoint}"/><Run Text=" ℃"/></TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- MESH table header -->
                    <Grid Grid.Row="1" x:Name="MeshHeaderGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="MESH"   FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="1"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="14"     FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="18.5"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="26"     FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="36"     FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="50"     FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="70"     FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="7"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="100"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="8"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="140"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="9"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="200"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="10" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="280"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="11" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="PAN" FontSize="7" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="12" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="2,2">
                            <TextBlock Text="AFS.FN" FontSize="7" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- 目開き row -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{loc:Loc Key=Report_MeshOpeningLabel}" FontSize="7" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="1"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M14}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M18}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M26}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M36}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M50}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M70}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="7"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M100}"  FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="8"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M140}"  FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="9"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M200}"  FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="10" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding M280}"  FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="11" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{Binding Pan}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="12" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="2,2">
                            <TextBlock Text="{Binding Pan}"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                    
                    <!-- 分布(%) row -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="{loc:Loc Key=Report_DistributionLabel}" FontSize="7" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                        <Border Grid.Column="1"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="1,180" FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="850"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="600"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="425"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="300"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="212"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="7"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="150"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="8"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="106"   FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="9"  BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="75"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="10" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="53"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="11" BorderBrush="#333333" BorderThickness="0,0,1,1" Padding="2,2">
                            <TextBlock Text="－"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="12" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="2,2">
                            <TextBlock Text="－"    FontSize="8" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                </Grid>
            </Border>

            <!-- ===== ROW 4: Chart ===== -->
            <Border Grid.Row="4" BorderBrush="#333333" BorderThickness="1" Margin="0,0,0,8" Padding="8">
                <ig:XamDataChart x:Name="ReportChart"
                    CrosshairVisibility="Collapsed"
                    Margin="0">
                    <ig:XamDataChart.Axes>
                        <ig:CategoryXAxis x:Name="rxAxis"
                            ItemsSource="{Binding ChartPoints}"
                            Label="{}{Label}"
                            Title="MESH"
                            Foreground="#333333"
                            MajorStroke="#DDDDDD"
                            Stroke="#AAAAAA"/>
                        <ig:NumericYAxis x:Name="ryAxis"
                            MinimumValue="0"
                            MaximumValue="{Binding ChartMaxY}"
                            Interval="10"
                            Foreground="#333333"
                            MajorStroke="#DDDDDD"
                            Stroke="#AAAAAA"/>
                    </ig:XamDataChart.Axes>
                    <ig:XamDataChart.Series>
                        <ig:LineSeries
                            XAxis="{Binding ElementName=rxAxis}"
                            YAxis="{Binding ElementName=ryAxis}"
                            ItemsSource="{Binding ChartPoints}"
                            ValueMemberPath="Value"
                            Brush="#333333"
                            Thickness="1.5"
                            MarkerType="Circle"
                            MarkerBrush="#333333"
                            MarkerOutline="#333333"/>
                    </ig:XamDataChart.Series>
                </ig:XamDataChart>
            </Border>

            <!-- ===== ROW 5: 備考 ===== -->
            <Border Grid.Row="5" BorderBrush="#333333" BorderThickness="1" MinHeight="50" Padding="6">
                <StackPanel>
                    <TextBlock Text="{loc:Loc Key=Report_RemarksLabel}" FontSize="9" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Remarks}" FontSize="10" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
