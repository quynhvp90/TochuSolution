<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
             xmlns:igEditors="http://infragistics.com/Editors" 
                xmlns:Enums="clr-namespace:IMIP.Tochu.Shared.Enums;assembly=IMIP.Tochu.Shared" xmlns:igDP="http://infragistics.com/DataPresenter" x:Class="IMIP.Tochu.WPF.Views.UserControls.SearchView"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="43*"/>
            <RowDefinition Height="130*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Search View" FontSize="20" Margin="0,0,0,38" Grid.RowSpan="2"/>

        <TextBox Grid.Row="1"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,10,0,10"/>

        <Button Grid.Row="2"
                Content="Go Back"
                Command="{Binding GoBackCommand}"
                VerticalAlignment="Top"/>

        <!-- XamDataGrid -->
        <igDP:XamDataGrid Grid.Row="3"
                          DataSource="{Binding Users}"
                          Theme="Aero">
            <igDP:XamDataGrid.FieldLayoutSettings>
                <igDP:FieldLayoutSettings AutoGenerateFields="False"
                                          AllowAddNew="False"
                                          AllowDelete="False"/>
            </igDP:XamDataGrid.FieldLayoutSettings>

            <igDP:XamDataGrid.FieldSettings>
                <igDP:FieldSettings AllowEdit="False"
                                    CellClickAction="SelectRecord"/>
            </igDP:XamDataGrid.FieldSettings>

            <igDP:XamDataGrid.FieldLayouts>
                <igDP:FieldLayout>
                    <igDP:FieldLayout.Fields>
                        <igDP:Field Name="Name"     Label="Name"     Width="200"/>
                        <igDP:Field Name="Email"    Label="Email"    Width="220"/>
                        <igDP:Field Name="IsActive" Label="Active"   Width="80"/>

                        <!-- Button Edit trong grid -->
                        <igDP:UnboundField Name="EditAction" Label=" " Width="80">
                            <igDP:UnboundField.Settings>
                                <igDP:FieldSettings AllowEdit="False"/>
                            </igDP:UnboundField.Settings>
                            <igDP:UnboundField.CellValuePresenterStyle>
                                <Style TargetType="igDP:CellValuePresenter">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <Button Content="Edit"
                                                        FontSize="12"
                                                        Padding="8,3"
                                                        Command="{Binding DataContext.EditCommand,
                                                                  RelativeSource={RelativeSource AncestorType=igDP:XamDataGrid}}"
                                                        CommandParameter="{Binding DataRecord.DataItem,
                                                                           RelativeSource={RelativeSource AncestorType=igDP:DataRecordPresenter}}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </igDP:UnboundField.CellValuePresenterStyle>
                        </igDP:UnboundField>

                    </igDP:FieldLayout.Fields>
                </igDP:FieldLayout>
            </igDP:XamDataGrid.FieldLayouts>
        </igDP:XamDataGrid>

    </Grid>
</UserControl>
