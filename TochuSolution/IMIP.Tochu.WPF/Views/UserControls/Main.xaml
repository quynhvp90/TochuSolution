<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:IMIP.Tochu.UI.ViewModels;assembly=IMIP.Tochu.UI"
             xmlns:local="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
             xmlns:ig="http://schemas.infragistics.com/xaml" x:Class="IMIP.Tochu.WPF.Views.UserControls.Main"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" MinHeight="27.6" />
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Main View" FontSize="20" Margin="0,0,0,1"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="513,13,28,0" Grid.ColumnSpan="1  " Height="67" VerticalAlignment="Top">
            <Button Content="Search"
                    Style="{StaticResource SoftBlueButton}"
                    Command="{Binding GoSearchCommand}"
                    Width="100"/>

            <Button Content="Master"
                    Style="{StaticResource SoftBlueButton}"
                    Command="{Binding GoMasterCommand}"
                    Width="100"
                    Margin="10,0,0,0"/>
        </StackPanel>

        <ig:XamButton Content="XamButton" HorizontalAlignment="Left" Margin="243,167,0,0" Grid.Row="1" VerticalAlignment="Top" Height="59" Width="116"/>

    </Grid>
</UserControl>
