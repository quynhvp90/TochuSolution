<UserControl xmlns:Inputs="clr-namespace:Infragistics.Controls.Inputs;assembly=Infragistics.WPF.Controls.Inputs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:IMIP.Tochu.WPF.Views.UserControls"
             xmlns:igEditors="http://infragistics.com/Editors"
             xmlns:igDP="http://infragistics.com/DataPresenter"
             x:Class="IMIP.Tochu.WPF.Views.UserControls.Search"
             xmlns:converters="clr-namespace:IMIP.Tochu.WPF.Converters"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             xmlns:vm="clr-namespace:IMIP.Tochu.WPF.ViewModels"
             xmlns:vmDesign="clr-namespace:IMIP.Tochu.WPF.DataDesign"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vmDesign:SearchDesignViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="800" d:DesignWidth="1000">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <!-- Search filter bar -->
            <RowDefinition Height="Auto"/>
            <!-- Grid 1: Search results (60%) -->
            <RowDefinition Height="6*"/>
            <!-- Grid 2: Performance data (40%) -->
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- FILTER BAR                                                  -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="12,8">
            <DockPanel LastChildFill="False">

                <!-- Delivery Date -->
                <TextBlock DockPanel.Dock="Left" Text="Delivery Date"
                   VerticalAlignment="Center" Margin="0,0,6,0"
                   FontSize="13" Foreground="#333"/>
                <igEditors:XamDateTimeEditor
                    Value="{Binding StartNoukidate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="130"
                    Height="26"
                    Format="yyyy/MM/dd"
                    IsReadOnly="False"
                    DropDownButtonDisplayMode="Always" Theme="Office2013" SpinButtonDisplayMode="Focused" DisplayMode="IncludePromptChars"/>
                <TextBlock DockPanel.Dock="Left" Text=" ~ "
                   VerticalAlignment="Center" Margin="4,0"
                   FontSize="13" Foreground="#333"/>
                <igEditors:XamDateTimeEditor
                    Value="{Binding EndNoukidate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="130"
                    Height="26"
                    Format="yyyy/MM/dd"
                    IsReadOnly="False"
                    DropDownButtonDisplayMode="Always" Theme="Office2013" SpinButtonDisplayMode="Focused" DisplayMode="IncludePromptChars"/>

                <!-- Search Button -->
                <Button DockPanel.Dock="Left"
                    Content="Search" Width="80" Height="26"
                    Command="{Binding Search}"
                    Style="{StaticResource BlueButtonStyle}"
                    VerticalAlignment="Center" Margin="10,0,16,0"
                    Cursor="Hand" FontSize="13">
                    
                </Button>

                <!-- Site Code -->

                <igEditors:XamTextEditor DockPanel.Dock="Right"
                    Text="{Binding BranchCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="120" Height="26" IsEnabled="False"
                    VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="Branch Code"
                   VerticalAlignment="Center" Margin="0,0,6,0"
                   FontSize="13" Foreground="#333"/>



            </DockPanel>
        </Border>
        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- GRID 1: ORDER SEARCH RESULTS (60%)                         -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="8,8,8,4" Background="White"
                BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#E3F2FD" Padding="10,6" BorderBrush="#BBDEFB" BorderThickness="0,0,0,1">
                    <TextBlock Text="Search Results" FontSize="13" FontWeight="SemiBold" Foreground="#1565C0"/>
                </Border>

                <!-- XamDataGrid 1 -->
                <igDP:XamDataGrid Grid.Row="1"
                    x:Name="JuchuuRCSGrid"
                    DataSource="{Binding JuchuuRCSItems}"
                    SelectedDataItem="{Binding SelectedJuchuuRCSItem, Mode=TwoWay}"
                    ActiveDataItem="{Binding SelectedJuchuuRCSItem, Mode=TwoWay}"
                    Theme="Office2013"
                    GroupByAreaLocation="None"
                    UpdateMode="OnCellChangeOrLostFocus" Background="White" >
                    <igDP:XamDataGrid.Resources>
                        <!--<Style TargetType="{x:Type igDP:LabelPresenter}"
                        BasedOn="{StaticResource BlueGridHeaderStyle}"/>-->
                        <converters:RowIndexToBackgroundConverter x:Key="RowIndexToBackground"/>

                        <!-- Row data background with alternating colors -->
                        <Style TargetType="{x:Type igDP:DataRecordPresenter}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <Binding Path="Record"
                                         RelativeSource="{RelativeSource Self}"
                                         Converter="{StaticResource RowIndexToBackground}"/>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D0E8FF"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsActive"   Value="False"/>
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>


                    </igDP:XamDataGrid.Resources>
                    <igDP:XamDataGrid.FieldLayoutSettings>
                        <igDP:FieldLayoutSettings AutoGenerateFields="False" DataRecordSizingMode="SizedToContentAndIndividuallySizable"
                                  SelectionTypeRecord="Default" AllowAddNew="False" AllowDelete="False" HeaderPrefixAreaDisplayMode="Menu" HighlightPrimaryField="Default" LabelLocation="Default" RecordSelectorLocation="Default" SelectionTypeField="Default"/>
                    </igDP:XamDataGrid.FieldLayoutSettings>

                    <igDP:XamDataGrid.FieldSettings>
                        <igDP:FieldSettings AllowEdit="False"
                            LabelClickAction="Nothing" AllowCellVirtualization="False" AllowGroupBy="False" AllowHiding="Never" AllowLabelVirtualization="False" AllowRecordFiltering="False" CellClickAction="SelectRecord" CellContentAlignment="Default" LabelTextAlignment="Center" LabelTextWrapping="WrapWithOverflow"/>
                    </igDP:XamDataGrid.FieldSettings>

                    <igDP:XamDataGrid.FieldLayouts>
                        <igDP:FieldLayout>
                            <igDP:FieldLayout.Fields>
                                <igDP:Field Name="JuchuuDenpyouNO" Label="Order No."        Width="90"/>
                                <igDP:Field Name="JuchuuYMD"       Label="Order Date"        Width="100" Format="yyyy/MM/dd"/>
                                <igDP:Field Name="Nouki"           Label="Delivery Date"     Width="100" Format="yyyy/MM/dd"/>
                                <igDP:Field Name="NouSSNM"         Label="Customer Name"     Width="160"/>
                                <igDP:Field Name="UserHinban"      Label="Customer Part No." Width="130"/>
                                <igDP:Field Name="UserHinmei"      Label="Product Name"      Width="160"/>
                                <igDP:Field Name="JuchuuSuu"       Label="Order Qty"         Width="80"/>
                                <igDP:Field Name="NouSCD"          Label="Customer Code"     Width="110"/>
                                <igDP:Field Name="TankaUnitCD"     Label="Unit"              Width="60"/>
                                <igDP:Field Name="NisugataCD"      Label="Package"           Width="90"/>
                                <igDP:Field Name="Tekiyou1"        Label="Note"              Width="*"/>
                            </igDP:FieldLayout.Fields>
                        </igDP:FieldLayout>
                    </igDP:XamDataGrid.FieldLayouts>

                    <igDP:XamDataGrid.ViewSettings>
                        <igDP:GridViewSettings/>
                    </igDP:XamDataGrid.ViewSettings>

                </igDP:XamDataGrid>
                <local:PagingControl Grid.Row="2" DataContext="{Binding JuChuuPaging}"/>
            </Grid>

        </Border>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- GRID 2: PERFORMANCE DATA RESULTS (40%)                     -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="8,4,8,8" Background="White"
                BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header with count + action buttons -->
                <Border Grid.Row="0" Background="#FFF8E1" Padding="10,6" BorderBrush="#FFE082" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- Count label -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Height="28">
                            <TextBlock Text="Performance Sheet Count " FontSize="13" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#E65100"/>

                            <igEditors:XamNumericEditor Text="{Binding SeninouDataPaging.TotalCount, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="60" Height="26" IsEnabled="False" Background="White" NullText="12"
                                VerticalAlignment="Center" HorizontalContentAlignment="Center" Theme="Office2013"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="1">
                            <Button Content="New"
                                Command="{Binding NewCommand}"
                                Style="{StaticResource GreenButtonStyle}"
                                Width="72"
                                Height="28"
                                Margin="0,0,8,0"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand">
                            </Button>

                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Button Content="Edit"
                                Command="{Binding EditCommand}"
                                Style="{StaticResource BlueButtonStyle}"
                                Width="72"
                                Height="28"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand">
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- XamDataGrid 2 -->
                <igDP:XamDataGrid Grid.Row="1"
                    DataSource="{Binding SeninouDataItems}"
                    SelectedDataItem="{Binding SelectedSeninouDataItem, Mode=TwoWay}"
                    ActiveDataItem="{Binding SelectedSeninouDataItem, Mode=TwoWay}"
                    Theme="Office2013"
                    GroupByAreaLocation="None"
                    DataSourceResetBehavior="ReuseRecordsViaEnumerator"
                    UpdateMode="OnCellChangeOrLostFocus" AutoFit="True">
                    <!--<igDP:XamDataGrid.Resources>
                        <Style TargetType="{x:Type igDP:LabelPresenter}"
                            BasedOn="{StaticResource OrangeGridHeaderStyle}"/>
                    </igDP:XamDataGrid.Resources>-->
                    <igDP:XamDataGrid.FieldLayoutSettings>
                        <igDP:FieldLayoutSettings AutoGenerateFields="False"
                                                  SelectionTypeRecord="Single"/>
                    </igDP:XamDataGrid.FieldLayoutSettings>

                    <igDP:XamDataGrid.FieldSettings>
                        <igDP:FieldSettings AllowEdit="False" LabelClickAction="SortByOneFieldOnly"/>
                    </igDP:XamDataGrid.FieldSettings>

                    <igDP:XamDataGrid.FieldLayouts>
                        <igDP:FieldLayout>
                            <igDP:FieldLayout.Fields>
                                <igDP:Field Name="JUCHUUNO"  Label="Order No."   Width="90"/>
                                <igDP:Field Name="NOUSCD"    Label="Code"        Width="100"/>
                                <igDP:Field Name="NUM"       Label="Sequence"    Width="80"/>
                                <igDP:Field Name="LOTNO"     Label="Lot No."     Width="120"/>
                                <igDP:Field Name="PRINTDT"   Label="Print Date"  Width="110" Format="yyyy/MM/dd"/>
                            </igDP:FieldLayout.Fields>
                        </igDP:FieldLayout>
                    </igDP:XamDataGrid.FieldLayouts>

                    <igDP:XamDataGrid.ViewSettings>
                        <igDP:GridViewSettings/>
                    </igDP:XamDataGrid.ViewSettings>
                </igDP:XamDataGrid>
                <local:PagingControl Grid.Row="2" DataContext="{Binding SeninouDataPaging}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
