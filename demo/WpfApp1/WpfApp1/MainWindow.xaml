<Window x:Class="WpfApp1.MainWindow"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MVVM Demo" Height="400" Width="600">
    <Grid>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10">
                <Button Content="Open Window" Command="{Binding OpenWindowCommand}" Margin="5"/>
                <Button Content="Show Message" Command="{Binding ShowMessageCommand}" Margin="5"/>
                <Button Content="Load UC" Command="{Binding LoadUserControlCommand}" Margin="5"/>
                <Button Content="Page 1" Command="{Binding GoPage1Command}" Margin="5"/>
                <Button Content="Page 2" Command="{Binding GoPage2Command}" Margin="5"/>
            </StackPanel>

            <ContentControl Content="{Binding CurrentView}" />
        </StackPanel>
    </Grid>
</Window>